{
    "name": "epistemic-audit-engine-root",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "postinstall": "npm install --prefix frontend",
        "dev": "concurrently -n \"BACKEND,FRONTEND\" -c \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:backend": "sh ./scripts/start-backend.sh",
        "dev:frontend": "cd frontend && npm run dev"
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}
